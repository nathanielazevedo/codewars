# Required — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -- Railway: these are auto-set by Railway plugins --
# DATABASE_URL=  (provided by Railway Postgres plugin)
# REDIS_URL=     (provided by Railway Redis plugin)

# -- Railway: set these on the web service --
# NEXTAUTH_URL=https://your-web-service.up.railway.app
# NEXT_PUBLIC_API_URL=https://your-api-service.up.railway.app

# -- Railway: set this on the api service --
# NEXTAUTH_URL=https://your-web-service.up.railway.app  (used for CORS origin)

# Piston — external EC2 instance URL
PISTON_URL=http://your-ec2-ip:2000
